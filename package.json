  "dependencies": {
    "@apollo/client": "3.5.10",
    "@apollo/server": "^4.10.0",
    "@types/node": "^20.10.6",
    "@types/react": "18.2.6",
    "@types/react-dom": "18.2.4",
    "apollo-client": "^2.6.10",
    "body-parser": "^1.20.2",
    "cors": "^2.8.4",
    "dataloader-sequelize": "^4.0.6",
    "graphql": "^16.6.0",
    "graphql-relay": "^0.6.0",
    "graphql-sequelize": "^9.4.0",
    "graphql-sequelize-generator": "^8.2.0",
    "graphql-ws": "^5.14.2",
    "pm2": "^5.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-scripts": "5.0.1",
    "sequelize": "6.28.0",
    "sqlite3": "^5.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^3.14.2",
    "typescript": "^5.3.3",
    "use-debounce": "^5.0.1",
    "ws": "^8.18.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "pm2 delete all -s; DEBUG=* pm2 startOrReload ecosystem.config.js && pm2 start react-scripts --name web -- start",
    "db-reset": "rm -f data/database.sqlite && ./node_modules/.bin/sequelize db:migrate --config config/config.json && ./node_modules/.bin/sequelize db:seed:all --config config/config.json",
    "db-migrate": "./node_modules/.bin/sequelize db:migrate --config config/config.json"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "@types/react": "18.2.6",
    "@types/react-dom": "18.2.4"
  },
  "devDependencies": {
    "sequelize-cli": "^6.3.0",
    "ts-node-dev": "^2.0.0"
  }
}
